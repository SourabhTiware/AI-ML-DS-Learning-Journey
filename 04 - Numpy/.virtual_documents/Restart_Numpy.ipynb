arr = np.array([[1,2],[3,4]])
mean = np.mean(arr)
std_dev = np.std(arr)

print((arr-mean) / std_dev)
print("\n")


# column wise
arr = np.array([ [1,2], [3,4] ,[5,6]])
mean = np.mean(arr, axis = 0)
std_dev = np.std(arr,axis = 0)
print((arr-mean)/std_dev)





# normalize

arr = np.array([ [1,2], [3,4] ])

mean = np.mean(arr)
std_dev = np.std(arr)

normalized_arr = (arr-mean) / std_dev
print(normalized_arr)

print(mean)
print(std_dev)



